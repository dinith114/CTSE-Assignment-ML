import sqlite3

conn = sqlite3.connect("app/data/doctors.db")
cursor = conn.cursor()

cursor.execute("DROP TABLE IF EXISTS doctors")

cursor.execute("""
CREATE TABLE doctors (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT,
    specialty TEXT,
    hospital TEXT,
    location TEXT,
    available_days TEXT
)
""")

cursor.execute("""
INSERT INTO doctors (name, specialty, hospital, location, available_days)
